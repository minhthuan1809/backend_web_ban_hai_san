-- product
CREATE TABLE layout_product (
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL ,
    description TEXT NOT NULL,
    image LONGTEXT NOT NULL DEFAULT 'https://picsum.photos/200',
    price DECIMAL(10, 2) NOT NULL,
    hot BOOLEAN NOT NULL DEFAULT true,
    rating DECIMAL(2, 1) NOT NULL ,
    category VARCHAR(255) NOT NULL DEFAULT 'crab', -- loại sản phẩm
    quantity INT NOT NULL DEFAULT 0, -- số lượng
    inStock BOOLEAN NOT NULL DEFAULT false, -- còn hàng hay không
    status BOOLEAN NOT NULL DEFAULT false, -- trạng thái sản phẩm
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);